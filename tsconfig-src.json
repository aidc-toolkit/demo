{
  "extends": "@aidc-toolkit/dev/tsconfig-template.json",
  "include": ["./src/**/*"],
  "compilerOptions": {
    // Modules.
    "types": ["vite-plugin-svgr/client"],

    // Emit.
    "outDir": "dist",

    // Editor support.
    "plugins": [{ "name": "typescript-plugin-css-modules" }],

    // Language and environment.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  }
}
